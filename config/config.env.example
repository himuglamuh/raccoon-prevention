# spotify-auto configuration  —  COPY to ~/.config/spotify-auto/config.env (0600)
# This file holds NO real secrets in the repo. Fill in your own values locally.
# It is parsed as simple KEY=value (no shell execution); quote values that
# contain spaces.

# --- Spotify app (PKCE: no client SECRET is ever needed by this tooling) ---
# Create an app at https://developer.spotify.com/dashboard and copy the Client ID.
CLIENT_ID=

# OAuth redirect URIs. BOTH must be registered verbatim in the Spotify dashboard.
#   - Local  (run `spotify-auto reauth` on the Pi; browser hits loopback)
#   - Remote (run `spotify-auto reauth --remote`; authorize from your phone over
#     the tailnet — Tailscale Serve terminates HTTPS and forwards to the local
#     listener on REMOTE_LISTEN_PORT)
REDIRECT_URI=http://127.0.0.1:8080/callback
REMOTE_REDIRECT_URI=https://CHANGE-ME.your-tailnet.ts.net/callback
REMOTE_LISTEN_PORT=8080

# What to auto-play when the kiosk goes idle (playlist/album/artist/track URI).
# Get it via Share -> Copy Spotify URI in the Spotify app.
CONTEXT_URI=spotify:playlist:CHANGE-ME

# Spotify Connect device name exposed by the Chromium web player.
DEVICE_NAME="Web Player (Chrome)"

# OAuth scopes (default covers read + control of playback).
SCOPES="user-read-playback-state user-modify-playback-state user-read-currently-playing"

# --- Idle heartbeat: random volume jiggle while playing on the kiosk ---
# Intentional: keeps the Connect session looking live. Percent range.
HEARTBEAT_VOL_MIN=20
HEARTBEAT_VOL_MAX=40

# --- Kiosk watchdog tuning (optional; defaults shown) ---
WATCHDOG_THRESHOLD=3
WATCHDOG_TIMEOUT=5
DEVTOOLS_URL=http://127.0.0.1:9222/json/version

# --- Telegram alerts (optional; run: spotify-auto notify --setup) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- marq-playing marquee target (optional; only if you use marq-playing) ---
MARQUEE_SSH_DEST=
MARQUEE_SSH_KEY=
MARQUEE_INTERVAL=30
